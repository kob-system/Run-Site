# Production build config (used by Vercel). NO SECRETS here — the real secrets
# (Supabase URL/keys, Anthropic, Resend) come from Vercel's Environment Variables
# at build/runtime. This file only disables the ESLint webpack plugin so the
# Vercel build (which runs with CI=true) doesn't fail on non-blocking lint
# warnings. The project already does this locally via the gitignored .env;
# this commits it so production builds are reproducible.
DISABLE_ESLINT_PLUGIN=true
